      <div class="editor flex lazy-editor" style=""><pre tabindex="0" class="lazy-virtualized" style="font-size: 14px; line-height: 19px;"><pre class="lazy-gutter"></pre><pre class="monaco-colorized colab-dark colab-dark" data-lang="notebook-python"><span><span class="mtk1">pca=PCA</span><span class="mtk14">()</span></span><br><span><span class="mtk1">X_pca=pca.fit_transform</span><span class="mtk14">(</span><span class="mtk1">X_scaled</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#select_pca&nbsp;using&nbsp;diffrent&nbsp;method</span></span><br><span><span class="mtk8">#kisers&nbsp;criterion</span></span><br><span><span></span></span><br><span><span class="mtk1">kaiser_pc_count=np.</span><span class="mtk17">sum</span><span class="mtk14">(</span><span class="mtk1">eigen_values&gt;</span><span class="mtk6">1</span><span class="mtk14">)</span></span><br><span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk5">"Number&nbsp;of&nbsp;selected&nbsp;PC:"</span><span class="mtk14">,</span><span class="mtk1">kaiser_pc_count</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk1">variance_ratio=pca.explained_variance_ratio_</span></span><br><span><span class="mtk1">cumulative_variance=variance_ratio.cumsum</span><span class="mtk14">()</span></span><br><span><span></span></span><br><span><span class="mtk8">#show&nbsp;components,their&nbsp;corresponding&nbsp;variance&nbsp;and&nbsp;</span><span class="mtk8">cumulative&nbsp;variance</span></span><br><span><span></span></span><br><span><span class="mtk1">df=pd.DataFrame</span><span class="mtk14">({</span></span><br><span><span class="mtk1">&nbsp;&nbsp;</span><span class="mtk5">"PC"</span><span class="mtk14">:</span><span class="mtk17">range</span><span class="mtk14">(</span><span class="mtk6">1</span><span class="mtk14">,</span><span class="mtk17">len</span><span class="mtk14">(</span><span class="mtk1">variance_ratio</span><span class="mtk14">)</span><span class="mtk1">+</span><span class="mtk6">1</span><span class="mtk14">),</span></span><br><span><span class="mtk1">&nbsp;&nbsp;</span><span class="mtk5">"Variance"</span><span class="mtk14">:</span><span class="mtk1">variance_ratio</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;</span><span class="mtk5">"Cumulative"</span><span class="mtk14">:</span><span class="mtk1">cumulative_variance</span></span><br><span><span class="mtk14">})</span></span><br><span><span></span></span><br><span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk1">df</span><span class="mtk14">)</span></span><br></pre><colab-read-only-cell-placeholder style="display: none;"><template shadowrootmode="open"><!----><div><!--?lit$533050084$-->Start coding or <span tabindex="0" role="button" class="link">generate</span> with AI.</div></template></colab-read-only-cell-placeholder></pre></div><colab-form class="formview vertical layout flex"><div class="widget-area"></div></colab-form></div>
